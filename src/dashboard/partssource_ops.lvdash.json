{
  "datasets": [
    {
      "name": "exec_kpis",
      "displayName": "Executive KPIs",
      "queryLines": [
        "SELECT\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      IDENTIFIER(:catalog || '.suppliers.gold_supplier_performance')\n",
        "  ) AS suppliers,\n",
        "  (\n",
        "    SELECT\n",
        "      ROUND(SUM(total_spend_usd), 0)\n",
        "    FROM\n",
        "      IDENTIFIER(:catalog || '.suppliers.gold_supplier_performance')\n",
        "  ) AS total_spend_usd,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      IDENTIFIER(:catalog || '.parts.gold_reorder_needed')\n",
        "  ) AS reorder_needed,\n",
        "  (\n",
        "    SELECT\n",
        "      SUM(work_orders)\n",
        "    FROM\n",
        "      IDENTIFIER(:catalog || '.service_ops.gold_work_order_volume')\n",
        "  ) AS total_work_orders,\n",
        "  (\n",
        "    SELECT\n",
        "      ROUND(AVG(sla_pct) * 100, 1)\n",
        "    FROM\n",
        "      IDENTIFIER(:catalog || '.service_ops.gold_sla_performance')\n",
        "  ) AS avg_sla_pct"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "supplier_spend",
      "displayName": "Supplier Spend",
      "queryLines": [
        "SELECT\n",
        "  supplier_name,\n",
        "  region,\n",
        "  tier,\n",
        "  composite_score,\n",
        "  total_spend_usd,\n",
        "  on_time_rate,\n",
        "  defect_rate_ppm\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.suppliers.gold_supplier_performance')\n",
        "WHERE\n",
        "  total_spend_usd IS NOT NULL\n",
        "ORDER BY\n",
        "  total_spend_usd DESC\n",
        "LIMIT 50"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "spend_by_region",
      "displayName": "Spend by Region & Tier",
      "queryLines": [
        "SELECT\n",
        "  region,\n",
        "  tier,\n",
        "  total_spend_usd,\n",
        "  supplier_count,\n",
        "  avg_composite_score\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.suppliers.gold_spend_by_region')\n",
        "ORDER BY\n",
        "  total_spend_usd DESC"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "reorder_needed",
      "displayName": "Reorder List",
      "queryLines": [
        "SELECT\n",
        "  part_name,\n",
        "  category,\n",
        "  manufacturer,\n",
        "  warehouse,\n",
        "  on_hand_qty,\n",
        "  reorder_point,\n",
        "  shortfall_qty,\n",
        "  list_price_usd,\n",
        "  ROUND(shortfall_qty * list_price_usd, 2) AS est_reorder_value_usd\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.parts.gold_reorder_needed')\n",
        "ORDER BY\n",
        "  shortfall_qty DESC\n",
        "LIMIT 100"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "pricing_benchmark",
      "displayName": "Pricing Benchmark",
      "queryLines": [
        "SELECT\n",
        "  part_name,\n",
        "  category,\n",
        "  manufacturer,\n",
        "  list_price_usd,\n",
        "  avg_paid_usd,\n",
        "  savings_vs_list_pct\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.parts.gold_part_pricing_benchmark')\n",
        "WHERE\n",
        "  savings_vs_list_pct IS NOT NULL\n",
        "ORDER BY\n",
        "  savings_vs_list_pct DESC\n",
        "LIMIT 100"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "work_order_volume",
      "displayName": "Work Orders by Month & Priority",
      "queryLines": [
        "SELECT\n",
        "  month,\n",
        "  priority,\n",
        "  SUM(work_orders) AS work_orders\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.service_ops.gold_work_order_volume')\n",
        "WHERE\n",
        "  status = 'closed'\n",
        "GROUP BY\n",
        "  month,\n",
        "  priority\n",
        "ORDER BY\n",
        "  month,\n",
        "  priority"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "sla_performance",
      "displayName": "SLA Attainment",
      "queryLines": [
        "SELECT\n",
        "  priority,\n",
        "  closed_orders,\n",
        "  orders_meeting_sla,\n",
        "  ROUND(sla_pct * 100, 1) AS sla_pct_display,\n",
        "  avg_duration_hours\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.service_ops.gold_sla_performance')\n",
        "ORDER BY\n",
        "  priority"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "part_demand_top",
      "displayName": "Top Parts by Monthly Demand",
      "queryLines": [
        "SELECT\n",
        "  d.part_id,\n",
        "  p.part_name,\n",
        "  p.category,\n",
        "  d.month,\n",
        "  d.work_orders,\n",
        "  d.avg_duration_hours\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.service_ops.gold_part_demand_monthly') d\n",
        "    JOIN IDENTIFIER(:catalog || '.parts.silver_parts') p USING (part_id)\n",
        "ORDER BY\n",
        "  d.work_orders DESC\n",
        "LIMIT 200"
      ],
      "parameters": [
        {
          "displayName": "Catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "partssource_demo"
                }
              ]
            }
          }
        }
      ]
    }
  ],
